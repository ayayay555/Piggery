---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Backyard Piggery | Caduhaan, Cadiz City">
	<main>
		<!-- Hero Section -->
		<section class="hero" style={`background-image: linear-gradient(rgba(44, 62, 32, 0.6), rgba(44, 62, 32, 0.8)), url('${import.meta.env.BASE_URL}/images/60818bea46deb36f46cf3c39a105d0fa.jpg');`}>
			<div class="hero-content">
				<span class="location-tag">📍 Brgy. Caduhaan, Cadiz City</span>
				<h1>Quality Backyard-Raised Pigs</h1>
				<p>Raised with natural care and fresh air in our Cadiz backyard. Premium livestock for your family celebrations and farm business.</p>
				<div class="hero-actions">
					<a href="tel:09852571859" class="cta-button">Call to Order</a>
					<a href="#products" class="secondary-button">See Available Pigs</a>
				</div>
			</div>
		</section>

		<!-- Our Story Section -->
		<section id="about" class="section">
			<div class="container grid-2">
				<div class="text-block">
					<span class="sub-headline">Our Heritage</span>
					<h2>A Handshake You Can Trust</h2>
					<p>In Cadiz, a deal is sealed with a handshake. Our backyard piggery in Caduhaan isn't just a business; it's a commitment to our community. We raise our pigs like family—giving them the space, natural feed, and clean environment they need to thrive.</p>
					<ul class="feature-list">
						<li>✅ 100% Backyard Raised</li>
						<li>✅ Fresh Air & Natural Environment</li>
						<li>✅ Trusted by the local community</li>
					</ul>
				</div>
				<div class="image-block">
					<img src={`${import.meta.env.BASE_URL}/images/c323f238789ae29abf48724963edd30f.jpg`} alt="Local farmers handshake agreement" class="rounded-img" width="600" height="400" loading="lazy" />
				</div>
			</div>
		</section>

		<!-- Available Pigs Section -->
		<section id="products" class="section bg-alt">
			<div class="container">
				<div class="text-center">
					<span class="sub-headline">Livestock</span>
					<h2>Currently Available</h2>
				</div>
				<div class="product-grid">
					<div class="product-card">
						<div class="product-img">
							<img src={`${import.meta.env.BASE_URL}/images/ad5bbe107969ff05eead66b0fff5becd.jpg`} alt="Healthy backyard piglets" width="400" height="280" loading="lazy" />
						</div>
						<h3>Healthy Piglets (Baktin)</h3>
						<p>Strong and active piglets, perfect for starting your own backyard fattening project.</p>
						<span class="price-tag">₱2,500 – ₱4,500</span>
					</div>
					<div class="product-card">
						<div class="product-img">
							<img src={`${import.meta.env.BASE_URL}/images/8bc36a2c1bcd0abb941db4b72ddb8125.jpg`} alt="Mature pig in backyard farm" width="400" height="280" loading="lazy" />
						</div>
						<h3>Mature Pigs (Anay)</h3>
						<p>Ready for the market or your special occasions. Lechon size available upon request.</p>
						<span class="price-tag">₱120 – ₱160 / kg</span>
					</div>
				</div>
			</div>
		</section>

		<!-- Price Section -->
		<section id="prices" class="section">
			<div class="container">
				<div class="text-center">
					<span class="sub-headline">Transparency</span>
					<h2>Market Price Guide</h2>
					<p>Based on latest Negros Occidental rates.</p>
				</div>
				<div class="price-table-wrapper">
					<table class="price-table">
						<thead>
							<tr>
								<th>Category</th>
								<th>Description</th>
								<th>Price Range</th>
							</tr>
						</thead>
						<tbody>
							<tr>
								<td><strong>Piglets</strong></td>
								<td>Healthy weanlings</td>
								<td>₱2,500 – ₱4,500</td>
							</tr>
							<tr>
								<td><strong>Liveweight</strong></td>
								<td>Mature pigs</td>
								<td>₱120 – ₱160 / kg</td>
							</tr>
							<tr>
								<td><strong>Retail Pork</strong></td>
								<td>Fresh farm meat</td>
								<td>₱250 – ₱340 / kg</td>
							</tr>
						</tbody>
					</table>
				</div>
			</div>
		</section>

		<!-- Location Section -->
		<section id="location" class="section bg-alt">
			<div class="container">
				<div class="grid-2">
					<div class="map-info">
						<span class="sub-headline">Visit Us</span>
						<h2>Our Location</h2>
						<p>Visit us in Brgy. Caduhaan, Cadiz City. Open daily for livestock viewing.</p>
						<ul class="location-details">
							<li>📍 Brgy. Caduhaan, Cadiz City</li>
							<li>⏰ 7:00 AM – 5:00 PM Daily</li>
						</ul>
						<a href="https://www.google.com/maps/search/Caduhaan+Cadiz+City" target="_blank" class="cta-button secondary-cta">View on Map</a>
					</div>
					<div class="map-embed">
						<iframe 
							src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d15651.423456789!2d123.315!3d10.952!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x33af9f!2sCaduhaan%2C%20Cadiz%20City%2C%20Negros%20Occidental!5e0!3m2!1sen!2sph!4v1234567890" 
							width="100%" height="300" style="border:0; border-radius: 12px; box-shadow: 10px 10px 0 var(--secondary);" allowfullscreen="" loading="lazy"></iframe>
					</div>
				</div>
			</div>
		</section>

		<!-- Final CTA Section -->
		<section id="contact-cta" class="section bg-dark text-center">
			<div class="container narrow">
				<span class="sub-headline" style="color: var(--secondary)">Get Started</span>
				<h2 class="text-white">Grow your farm today</h2>
				<p>Call Tatay now for orders and inquiries.</p>
				<div style="margin-top: 2rem;">
					<a href="tel:09852571859" class="cta-button large">📞 09852571859</a>
				</div>
			</div>
		</section>
	</main>
</Layout>

<style>
	/* General Layout - Mobile First */
	.text-center { text-align: center; }
	.section { padding: 50px 15px; }
	.container { max-width: 1100px; margin: 0 auto; width: 100%; }
	.container.narrow { max-width: 700px; }
	
	/* Typography - Fluid */
	h2 { font-size: clamp(1.8rem, 5vw, 2.8rem); margin-bottom: 1rem; color: var(--primary); line-height: 1.2; }
	.sub-headline { display: block; color: var(--accent); font-weight: bold; text-transform: uppercase; letter-spacing: 1.5px; margin-bottom: 0.75rem; font-size: 0.75rem; }

	/* Hero Section */
	.hero {
		position: relative;
		background-size: cover;
		background-position: center;
		min-height: 70vh;
		display: flex;
		align-items: center;
		justify-content: center;
		text-align: center;
		color: white;
		padding: 40px 20px;
	}
	.hero-content { position: relative; z-index: 10; width: 100%; }
	.location-tag { display: inline-block; background: var(--secondary); color: var(--text); padding: 4px 12px; border-radius: 6px; font-weight: bold; margin-bottom: 1rem; font-size: 0.8rem; }
	.hero h1 { font-size: clamp(2.2rem, 10vw, 4.5rem); line-height: 1.1; margin-bottom: 1rem; color: var(--white); text-shadow: 2px 2px 4px rgba(0,0,0,0.5); }
	.hero p { font-size: clamp(1rem, 3vw, 1.3rem); margin-bottom: 2rem; max-width: 700px; margin-left: auto; margin-right: auto; opacity: 0.95; }
	
	.hero-actions { display: flex; flex-direction: column; gap: 12px; align-items: center; }
	.cta-button, .secondary-button { width: 100%; max-width: 300px; padding: 15px 25px; border-radius: 8px; text-decoration: none; font-weight: bold; font-size: 1rem; text-align: center; transition: 0.3s; }
	
	.cta-button { background: var(--accent); color: white !important; box-shadow: 0 4px 0 #c05a3f; }
	.secondary-button { background: rgba(255,255,255,0.15); backdrop-filter: blur(5px); color: white; border: 2px solid white; }

	/* Grids - Stack on Mobile */
	.grid-2 { display: grid; grid-template-columns: 1fr; gap: 30px; align-items: center; text-align: center; }
	
	/* Features & Story */
	.feature-list { list-style: none; padding: 0; margin-top: 1.5rem; text-align: left; max-width: 400px; margin-left: auto; margin-right: auto; }
	.feature-list li { margin-bottom: 0.75rem; font-weight: 600; font-size: 1rem; }
	.rounded-img { width: 100%; height: auto; border-radius: 12px; box-shadow: 10px 10px 0 var(--secondary); border: 3px solid var(--white); }

	/* Product Cards */
	.product-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 25px; margin-top: 2rem; }
	.product-card { background: var(--white); border-radius: 12px; padding-bottom: 1.5rem; text-align: center; border: 1px solid rgba(0,0,0,0.05); box-shadow: 0 4px 10px rgba(0,0,0,0.05); }
	.product-img { padding: 10px; }
	.product-img img { width: 100%; aspect-ratio: 4/3; object-fit: cover; border-radius: 8px; }
	.price-tag { display: inline-block; margin-top: 1rem; font-weight: bold; color: var(--white); background: var(--primary); padding: 6px 20px; border-radius: 6px; }

	/* Price Table */
	.price-table-wrapper { margin-top: 2rem; background: var(--white); padding: 15px; border-radius: 12px; overflow-x: auto; border: 1px solid rgba(0,0,0,0.05); }
	.price-table { width: 100%; border-collapse: collapse; min-width: 450px; text-align: left; }
	.price-table th { background: var(--primary); color: white; padding: 12px; font-size: 0.8rem; text-transform: uppercase; }
	.price-table td { padding: 15px 12px; border-bottom: 1px solid #eee; font-size: 0.95rem; }

	/* Location */
	.location-details { list-style: none; padding: 0; margin: 1.5rem 0; text-align: center; }
	.location-details li { margin-bottom: 0.5rem; font-size: 1rem; }
	.secondary-cta { background: var(--primary) !important; box-shadow: 0 4px 0 #1a2a14 !important; }

	/* Desktop Adjustments */
	@media (min-width: 768px) {
		.section { padding: 80px 20px; }
		.hero { height: 85vh; }
		.hero-actions { flex-direction: row; justify-content: center; gap: 15px; }
		.hero-actions .cta-button, .hero-actions .secondary-button { width: auto; }
		.grid-2 { grid-template-columns: 1fr 1fr; text-align: left; gap: 60px; }
		.feature-list { margin-left: 0; }
		.location-details { text-align: left; }
		.price-table-wrapper { padding: 30px; }
		.rounded-img { box-shadow: 15px 15px 0 var(--secondary); }
	}

	.bg-alt { background-color: #EAE3C8; background-image: repeating-linear-gradient(45deg, rgba(44, 62, 32, 0.03) 0px, rgba(44, 62, 32, 0.03) 2px, transparent 2px, transparent 15px); }
	.bg-dark { background: var(--primary); color: white; border-top: 4px solid var(--secondary); border-bottom: 4px solid var(--secondary); }
	.text-white { color: white; }
</style>
