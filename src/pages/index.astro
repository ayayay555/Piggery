---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Backyard Piggery | Caduhaan, Cadiz City">
	<main>
		<!-- Hero Section -->
		<section class="hero" style={`background-image: linear-gradient(rgba(44, 62, 32, 0.6), rgba(44, 62, 32, 0.8)), url('${import.meta.env.BASE_URL}/images/60818bea46deb36f46cf3c39a105d0fa.jpg');`}>
			<div class="hero-content">
			
				<h1>Quality Backyard-Raised Pigs</h1>
				<p>Raised with natural care and fresh air in our Cadiz backyard. Premium livestock for your family celebrations and farm business.</p>
				<div class="hero-actions">
					<a href="tel:09852571859" class="cta-button">Call to Order: 09852571859</a>
					<a href="#products" class="secondary-button">See Available Pigs</a>
				</div>
			</div>
		</section>

		<!-- Our Story Section -->
		<section id="about" class="section">
			<div class="container grid-2">
				<div class="text-block">
					<span class="sub-headline">Our Heritage</span>
					<h2>A Handshake You Can Trust</h2>
					<p>In Cadiz, a deal is sealed with a handshake. Our backyard piggery in Caduhaan isn't just a business; it's a commitment to our community. We raise our pigs like family—giving them the space, natural feed, and clean environment they need to thrive. No industrial shortcuts, just honest backyard farming.</p>
					<ul class="feature-list">
						<li>✅ 100% Backyard Raised (Not a factory)</li>
						<li>✅ Fresh Air & Natural Environment</li>
						<li>✅ Trusted by the local community for years</li>
					</ul>
				</div>
				<div class="image-block">
					<img src={`${import.meta.env.BASE_URL}/images/c323f238789ae29abf48724963edd30f.jpg`} alt="Local farmers handshake agreement" class="rounded-img" width="600" height="400" loading="lazy" />
				</div>
			</div>
		</section>

		<!-- Available Pigs Section -->
		<section id="products" class="section bg-alt">
			<div class="container">
				<span class="sub-headline">Livestock</span>
				<h2>Currently Available</h2>
				<div class="product-grid">
					<div class="product-card">
						<div class="product-img">
							<img src={`${import.meta.env.BASE_URL}/images/ad5bbe107969ff05eead66b0fff5becd.jpg`} alt="Healthy backyard piglets" width="400" height="280" loading="lazy" />
						</div>
						<h3>Healthy Piglets (Baktin)</h3>
						<p>Strong and active piglets, perfect for starting your own backyard fattening project.</p>
						<span class="price-tag">₱4,500 / Head</span>
					</div>
					<div class="product-card">
						<div class="product-img">
							<img src={`${import.meta.env.BASE_URL}/images/8bc36a2c1bcd0abb941db4b72ddb8125.jpg`} alt="Mature pig in backyard farm" width="400" height="280" loading="lazy" />
						</div>
						<h3>Mature Pigs (Anay/Fatteners)</h3>
						<p>Ready for the market or your special occasions. Lechon size available upon request.</p>
						<span class="price-tag">₱195 / kg</span>
					</div>
				</div>
			</div>
		</section>

		<!-- Tips Section -->
		<section id="tips" class="section">
			<div class="container">
				<span class="sub-headline">Farm Wisdom</span>
				<h2>Backyard Raising Tips</h2>
				<div class="tips-grid">
					<div class="tip-item">
						<div class="tip-icon">🍚</div>
						<h3>Natural Feed (Dukot)</h3>
						<p>Mixing local rice bran with chopped banana trunks keeps the meat lean and flavorful.</p>
					</div>
					<div class="tip-item">
						<div class="tip-icon">🍃</div>
						<h3>Clean & Green</h3>
						<p>We use fresh leaves and rice hulls to keep the pens odorless—the natural way.</p>
					</div>
					<div class="tip-item">
						<div class="tip-icon">☀️</div>
						<h3>Morning Sun</h3>
						<p>Ensure your pigs get early morning sunlight for natural Vitamin D and better health.</p>
					</div>
				</div>
			</div>
		</section>

		<!-- Testimonials -->
		<section id="testimonials" class="section bg-dark">
			<div class="container">
				<span class="sub-headline">Feedback</span>
				<h2 class="text-white">What our Ka-Barangay Says</h2>
				<div class="testimonial-grid">
					<div class="testimonial-card">
						<p>"Nami ang ila baktin, wala gid kami gin hatagan sang labay-labay. Matambok kag baskog gid!"</p>
						<span class="client-name">— Tatay Noli, Caduhaan Buyer</span>
					</div>
					<div class="testimonial-card">
						<p>"Cleanest backyard farm I've seen in Cadiz. The owner is very honest and easy to talk to."</p>
						<span class="client-name">— Ma'am Elena, Local Reseller</span>
					</div>
				</div>
			</div>
		</section>

		<!-- FAQ Section -->
		<section id="faq" class="section">
			<div class="container narrow">
				<h2>Common Questions</h2>
				<div class="faq-item">
					<h3>Do you deliver within Cadiz City?</h3>
					<p>Yes! We can deliver within Cadiz City proper and nearby areas for bulk orders or multiple piglets.</p>
				</div>
				<div class="faq-item">
					<h3>What kind of feed do you use?</h3>
					<p>We use a balanced mix of commercial feed and natural supplements like rice bran and greens to ensure the best meat quality.</p>
				</div>
			</div>
		</section>

		<!-- Final CTA Section -->
		<section id="contact-cta" class="section bg-alt contact-cta">
			<div class="container narrow text-center">
				<span class="sub-headline">Get Started</span>
				<h2>Ready to grow your farm?</h2>
				<p>Whether you need a single piglet or a batch for your business, we are ready to help. Visit us in Caduhaan or give us a call today.</p>
				<div class="cta-box">
					<a href="tel:09852571859" class="cta-button large">📞 Call Us Now: 09852571859</a>
					<p class="small-note">Open daily for visits and inquiries.</p>
				</div>
			</div>
		</section>
	</main>
</Layout>

<style>
	/* Hero Section */
	.text-center { text-align: center; }
	.hero {
		position: relative;
		/* background: url('/images/60818bea46deb36f46cf3c39a105d0fa.jpg'); */ /* Moved to inline style for BASE_URL support */
		background-size: cover;
		background-position: center;
		height: 85vh;
		display: flex;
		align-items: center;
		justify-content: center;
		text-align: center;
		color: white;
	}
	/* .hero-overlay { ... } */ /* Removed as we use gradient in background-image now */
	.hero-content { position: relative; z-index: 10; padding: 0 20px; }
	.location-tag { display: inline-block; background: var(--secondary); color: var(--text); padding: 5px 15px; border-radius: 8px; font-weight: bold; margin-bottom: 1rem; font-size: 0.9rem; border: 1px solid rgba(0,0,0,0.1); }
	.hero h1 { font-size: clamp(2.5rem, 8vw, 4.5rem); line-height: 1.1; margin-bottom: 1.5rem; color: var(--white); text-shadow: 2px 2px 4px rgba(0,0,0,0.5); }
	.hero p { font-size: 1.3rem; margin-bottom: 2.5rem; max-width: 700px; margin-left: auto; margin-right: auto; opacity: 0.95; text-shadow: 1px 1px 2px rgba(0,0,0,0.5); }

	/* General Layout */
	.section { padding: 80px 20px; }
	.bg-alt { 
		background-color: #EAE3C8; /* Darker rustic tone */
		background-image: repeating-linear-gradient(45deg, rgba(44, 62, 32, 0.03) 0px, rgba(44, 62, 32, 0.03) 2px, transparent 2px, transparent 15px);
	}
	.bg-dark { background: var(--primary); color: white; border-top: 4px solid var(--secondary); border-bottom: 4px solid var(--secondary); }
	.container { max-width: 1100px; margin: 0 auto; }
	.container.narrow { max-width: 700px; }
	.grid-2 { display: grid; grid-template-columns: 1fr 1fr; gap: 60px; align-items: center; text-align: left; }
	
	.sub-headline { display: block; color: var(--accent); font-weight: bold; text-transform: uppercase; letter-spacing: 2px; margin-bottom: 1rem; font-size: 0.85rem; }
	h2 { font-size: 2.8rem; margin-bottom: 1.5rem; color: var(--primary); line-height: 1.2; }
	.text-white { color: white; }

	/* Features & Products */
	.feature-list { list-style: none; padding: 0; margin-top: 2rem; }
	.feature-list li { margin-bottom: 1rem; font-weight: 600; font-size: 1.1rem; }
	.rounded-img { 
		width: 100%; 
		height: auto;
		border-radius: 12px; 
		box-shadow: 15px 15px 0 var(--secondary); 
		border: 4px solid var(--white);
	}

	.product-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 40px; margin-top: 3rem; }
	.product-card { 
		background: var(--white); 
		border-radius: 12px; 
		overflow: hidden; 
		box-shadow: 0 4px 15px rgba(0,0,0,0.08); 
		transition: transform 0.3s; 
		padding-bottom: 2rem; 
		text-align: center;
		border: 1px solid rgba(0,0,0,0.05);
	}
	.product-card:hover { transform: translateY(-8px); box-shadow: 0 8px 25px rgba(0,0,0,0.12); }
	.product-img { padding: 15px; }
	.product-img img { 
		width: 100%; 
		height: auto;
		aspect-ratio: 4/3;
		object-fit: cover; 
		border-radius: 8px;
	}

	.price-tag { 
		display: inline-block; 
		margin-top: 1.5rem; 
		font-weight: bold; 
		color: var(--white); 
		background: var(--primary); 
		padding: 8px 24px; 
		border-radius: 6px; 
		font-size: 1.1rem;
	}

	/* Tips Section with Rustic Vibe */
	.tips-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(250px, 1fr)); gap: 30px; margin-top: 3rem; }
	.tip-item { 
		padding: 30px; 
		background: rgba(255, 255, 255, 0.6); 
		border-radius: 12px; 
		border: 1px solid var(--secondary);
		box-shadow: 4px 4px 0 var(--secondary);
		transition: transform 0.2s;
	}
	.tip-item:hover { transform: translate(-2px, -2px); box-shadow: 6px 6px 0 var(--secondary); }
	.tip-icon { font-size: 2.5rem; margin-bottom: 1rem; }
	.tip-item h3 { margin-top: 0; color: var(--primary); }

	/* Testimonials */
	.testimonial-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 30px; margin-top: 3rem; }
	.testimonial-card { background: rgba(255,255,255,0.05); padding: 35px; border-radius: 12px; font-style: italic; border: 1px solid rgba(255,255,255,0.1); position: relative; }
	.testimonial-card::before { content: '"'; font-size: 4rem; color: var(--secondary); opacity: 0.3; position: absolute; top: 10px; left: 20px; font-family: serif; }
	.client-name { display: block; margin-top: 1.5rem; font-weight: bold; color: var(--secondary); font-style: normal; }

	/* FAQ */
	.faq-item { text-align: left; margin-bottom: 2rem; background: var(--white); padding: 25px; border-radius: 12px; border-left: 6px solid var(--accent); box-shadow: 0 4px 10px rgba(0,0,0,0.03); }
	.faq-item h3 { color: var(--primary); margin-bottom: 0.7rem; font-size: 1.3rem; margin-top: 0; }
	.faq-item p { margin-bottom: 0; }

	/* Final CTA Section */
	.contact-cta { text-align: center; border-top: 1px solid rgba(0,0,0,0.1); }
	.cta-box { margin-top: 2.5rem; }
	.cta-button.large { font-size: 1.3rem; padding: 22px 50px; display: inline-block; }
	.small-note { margin-top: 1rem; font-size: 0.9rem; opacity: 0.7; font-style: italic; }

	/* Buttons */
	.hero-actions { display: flex; gap: 15px; justify-content: center; margin-top: 2rem; }
	.cta-button { background: var(--accent); color: white !important; padding: 18px 40px; border-radius: 8px; text-decoration: none; font-weight: bold; font-size: 1.1rem; transition: 0.3s; box-shadow: 0 4px 0 #c05a3f; border: none; cursor: pointer; }
	.cta-button:hover { background: #d96246; transform: translateY(2px); box-shadow: 0 2px 0 #c05a3f; }
	.secondary-button { background: rgba(255,255,255,0.15); backdrop-filter: blur(5px); color: white; padding: 18px 40px; border-radius: 8px; text-decoration: none; font-weight: bold; font-size: 1.1rem; border: 2px solid white; transition: 0.3s; }
	.secondary-button:hover { background: white; color: var(--primary); }

	@media (max-width: 768px) {
		.grid-2 { grid-template-columns: 1fr; text-align: center; }
		.hero h1 { font-size: 2.8rem; }
		.hero-actions { flex-direction: column; }
		.testimonial-grid { grid-template-columns: 1fr; }
		.section { padding: 60px 20px; }
		.rounded-img { box-shadow: 10px 10px 0 var(--secondary); }
		.cta-button.large { width: 100%; padding: 20px 20px; font-size: 1.1rem; }
	}
</style>