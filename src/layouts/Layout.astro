---
interface Props {
	title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/png" href={`${import.meta.env.BASE_URL}/images/logo.png`} />
		<meta name="generator" content={Astro.generator} />
		
		<!-- Primary Meta Tags -->
		<title>{title}</title>
		<meta name="title" content={title} />
		<meta name="description" content="Premium backyard-raised pigs in Caduhaan, Cadiz City. Naturally raised, healthy livestock for farm business and family celebrations." />

		<!-- Open Graph / Facebook -->
		<meta property="og:type" content="website" />
		<meta property="og:url" content="https://ayayay555.github.io/Piggery/" />
		<meta property="og:title" content={title} />
		<meta property="og:description" content="Premium backyard-raised pigs in Caduhaan, Cadiz City. Naturally raised, healthy livestock." />
		<meta property="og:image" content={`${import.meta.env.BASE_URL}/images/logo.png`} />

		<!-- Twitter -->
		<meta property="twitter:card" content="summary_large_image" />
		<meta property="twitter:title" content={title} />
		<meta property="twitter:description" content="Premium backyard-raised pigs in Caduhaan, Cadiz City. Naturally raised, healthy livestock." />
		<meta property="twitter:image" content={`${import.meta.env.BASE_URL}/images/logo.png`} />

		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Bricolage+Grotesque:opsz,wght@12..96,700&family=Lora:ital,wght@0,400;0,600;1,400&family=Inter:wght@400;600&display=swap" rel="stylesheet">
	</head>
	<body>
		<header class="site-header">
			<div class="container header-container">
				<a href={import.meta.env.BASE_URL} class="logo-wrapper">
					<img src={`${import.meta.env.BASE_URL}/images/logo.png`} alt="Backyard Piggery Logo" class="header-logo" />
					<span class="logo-text">Backyard Piggery</span>
				</a>
				<nav class="site-nav">
					<a href={`${import.meta.env.BASE_URL}/#about`}>About Us</a>
					<a href={`${import.meta.env.BASE_URL}/#contact`}>Contact Us</a>
				</nav>
			</div>
		</header>
		<slot />
		<footer id="contact" class="site-footer">
			<div class="container footer-container">
				<div class="footer-info">
					<h3>Backyard Piggery</h3>
					<p>Honest, natural, and trusted by the local community.</p>
				</div>
				<div class="footer-contact">
					<h4>Contact Us</h4>
					<p>📞 <a href="tel:09852571859">09852571859</a></p>
					<p>📍 Brgy. Caduhaan, Cadiz City</p>
				</div>
			</div>
			<div class="footer-bottom">
				<p>&copy; {new Date().getFullYear()} Backyard Piggery. All rights reserved.</p>
			</div>
		</footer>
	</body>
</html>
	<style is:global>
	:root {
		--primary: #2C3E20; /* Darker, rustic green */
		--secondary: #D4A373; /* Earthy wood/wheat tone */
		--accent: #E76F51; /* Terracotta / Clay */
		--bg: #F4EEDD; /* Rustic warm paper */
		--text: #3E2723; /* Deep dark brown */
		--white: #ffffff;
		--paper-texture: url("data:image/svg+xml,%3Csvg width='100' height='100' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.8' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100' height='100' filter='url(%23noise)' opacity='0.08'/%3E%3C/svg%3E");
	}
	html {
		font-family: 'Inter', sans-serif;
		background-color: var(--bg);
		background-image: var(--paper-texture);
		color: var(--text);
		scroll-behavior: smooth;
	}
	h1, h2, h3, h4 {
		font-family: 'Bricolage Grotesque', sans-serif;
		text-wrap: balance;
		color: var(--primary);
	}
	p, li, .testimonial-card {
		font-family: 'Lora', serif;
		line-height: 1.6;
	}
	body {
		margin: 0;
		padding: 0;
		display: flex;
		flex-direction: column;
		min-height: 100vh;
	}
	
	/* Header Styles */
	.site-header {
		background-color: var(--primary);
		color: var(--white);
		padding: 0.75rem 0;
		position: sticky;
		top: 0;
		z-index: 1000;
		box-shadow: 0 4px 10px rgba(0,0,0,0.15);
		border-bottom: 4px solid var(--secondary);
	}
	.header-container {
		display: flex;
		justify-content: space-between;
		align-items: center;
		padding: 0 20px;
		max-width: 1100px;
		margin: 0 auto;
	}
	.logo-wrapper {
		display: flex;
		align-items: center;
		gap: 12px;
		text-decoration: none;
	}
	.header-logo {
		height: 50px;
		width: auto;
		transition: transform 0.3s ease;
		/* Professional filter to turn black PNG into Golden Wheat color */
		filter: brightness(0) saturate(100%) invert(85%) sepia(21%) saturate(615%) hue-rotate(351deg) brightness(96%) contrast(88%);
	}
	.logo-wrapper:hover .header-logo {
		transform: scale(1.1) rotate(-3deg);
	}
	.logo-text {
		color: var(--secondary);
		font-family: 'Bricolage Grotesque', sans-serif;
		font-size: 1.4rem;
		font-weight: 700;
		letter-spacing: 0.5px;
	}
	.site-nav a {
		color: var(--white);
		text-decoration: none;
		margin-left: 1.5rem;
		font-weight: 600;
		font-family: 'Inter', sans-serif;
		transition: color 0.3s ease;
		font-size: 0.95rem;
		text-transform: uppercase;
		letter-spacing: 1px;
	}
	.site-nav a:hover {
		color: var(--secondary);
	}

	/* Footer Styles */
	.site-footer {
		background-color: var(--primary);
		color: var(--white);
		padding: 3rem 0 1rem;
		margin-top: auto;
		border-top: 6px solid var(--secondary);
	}
	.footer-container {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 2rem;
		padding: 0 20px;
		max-width: 1100px;
		margin: 0 auto;
		margin-bottom: 2rem;
	}
	.footer-info h3, .footer-contact h4 {
		color: var(--secondary);
		margin-top: 0;
		margin-bottom: 1rem;
	}
	.footer-contact p {
		margin: 0.5rem 0;
		display: flex;
		align-items: center;
		gap: 0.5rem;
	}
	.footer-contact a {
		color: var(--white);
		text-decoration: none;
		transition: color 0.3s;
	}
	.footer-contact a:hover {
		color: var(--secondary);
	}
	.footer-bottom {
		text-align: center;
		padding-top: 1.5rem;
		border-top: 1px solid rgba(255,255,255,0.1);
		font-size: 0.9rem;
		opacity: 0.8;
	}
	
	@media (max-width: 768px) {
		.header-container {
			flex-direction: column;
			gap: 1rem;
		}
		.site-nav a {
			margin: 0 0.75rem;
		}
		.footer-container {
			grid-template-columns: 1fr;
			text-align: center;
		}
		.footer-contact p {
			justify-content: center;
		}
	}
</style>
